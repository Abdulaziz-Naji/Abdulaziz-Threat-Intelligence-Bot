# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── VirusTotal ──────────────────────────────────────────────────────────────
# Free tier: 500 requests/day — https://www.virustotal.com/gui/my-apikey
VT_API_KEY=your_virustotal_api_key_here

# ─── AbuseIPDB ───────────────────────────────────────────────────────────────
# Free tier: 1000 requests/day — https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# ─── AlienVault OTX ──────────────────────────────────────────────────────────
# Free — https://otx.alienvault.com/api
OTX_API_KEY=your_otx_api_key_here

# ─── abuse.ch (MalwareBazaar / ThreatFox / URLHaus) ─────────────────────────
# Free — https://abuse.ch/
ABUSE_CH_API_KEY=your_abuse_ch_api_key_here

# ─── HaveIBeenPwned (HIBP) ───────────────────────────────────────────────────
# Paid API key — https://haveibeenpwned.com/API/Key
# Used by /email for breach intelligence. Optional — omit to disable.
HIBP_API_KEY=your_hibp_api_key_here

# ─── Access Control ──────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow all users (open access).
# Example: AUTHORIZED_USERS=123456789,987654321
AUTHORIZED_USERS=

# ─── Monitoring Intervals ────────────────────────────────────────────────────
# How often to check watchlist IOCs (minutes). Default: 60
MONITOR_INTERVAL_MINUTES=60

# How often to pull threat intelligence feeds (minutes). Default: 120
FEED_CHECK_INTERVAL_MINUTES=120
